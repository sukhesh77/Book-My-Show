pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'feature-devops', url: 'https://github.com/sukhesh77/Book-My-Show.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('bookmyshow-app') {
                    sh 'npm install'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('bookmyshow-app') {
                    withSonarQubeEnv('sonar-server') {
                        sh """
                        ${tool 'sonar-scanner'}/bin/sonar-scanner \
                        -Dsonar.projectKey=BMS-app \
                        -Dsonar.sources=. \
                        -Dsonar.exclusions=node_modules/**
                        """
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('bookmyshow-app') {
                    sh 'docker build -t sukhesh77/bookmyshow-app:v1.0.0 .'
                }
            }
        }

        stage('Run Docker Container') {
            steps {
                sh '''
                docker rm -f bookmyshow-container || true
                docker run -d -p 3000:3000 --name bookmyshow-container sukhesh77/bookmyshow-app:v1.0.0
                '''
            }
        }
    }

    post {

        success {
            emailext(
                subject: "Jenkins Build SUCCESS",
                body: "Pipeline executed successfully.",
                to: "saisukhesh09123@gmail.com"
            )
        }

        failure {
            emailext(
                subject: "Jenkins Build FAILED",
                body: "Pipeline execution FAILED. Check Jenkins logs.",
                to: "saisukhesh09123@gmail.com"
            )
        }

        always {
            echo "Pipeline finished."
        }
    }
}

